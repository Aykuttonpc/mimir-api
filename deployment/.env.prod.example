# Mimir Production Environment — TEMPLATE
# Gerçek değerleri /opt/mimir/.env.prod dosyasına koy. Bu dosyayı KESİNLİKLE git'e commit etme.

# --- Database ---
DB_USER=mimir
DB_PASSWORD=                      # 32+ karakter random; openssl rand -base64 32
DB_NAME=mimir

# --- Redis ---
REDIS_PASSWORD=                   # 32+ karakter random; openssl rand -base64 32

# --- Web image ---
WEB_TAG=                          # T-007 sonrası: semver (v0.1.0) veya commit SHA. 'latest' YASAK.

# --- JWT ---
JWT_KEY=                          # 64+ karakter random; openssl rand -base64 64
JWT_ISSUER=mimir-api
JWT_AUDIENCE=mimir-mobile

# --- SMTP (email verification — tek doğrulama kanalı, ADR-010) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Bootstrap Admin (ilk admin user; Mimir API ilk açılışta bunu yaratır) ---
# Sadece ilk kez gerekli — admin user yaratıldıktan sonra silinebilir/değiştirilebilir.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_USERNAME=aykut

# --- Message crypto key (ADR-012, AES-256-GCM) ---
# 32 byte = Base64 44 char. Server-side: openssl rand -base64 32
# KAYBOLURSA TÜM MEVCUT MESAJLAR DEŞİFRELENEMEZ — backup şart!
CRYPTO_MESSAGE_KEY=

# --- T-039 force-update (Android) ---
# MIN_APP_VERSION_ANDROID: bu sürümden eski APK'lar bloklanır (force update screen)
# LATEST_APP_VERSION_ANDROID: kullanıcıya gösterilen önerilen sürüm
# APP_DOWNLOAD_URL_ANDROID: APK indirme linki (örn. cloud storage public URL veya direct)
MIN_APP_VERSION_ANDROID=0.1.0
LATEST_APP_VERSION_ANDROID=0.1.0
APP_DOWNLOAD_URL_ANDROID=
